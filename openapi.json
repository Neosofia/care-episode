    "/api/v1/care-episodes/{patient_uuid}/chat/interactions": {
      "post": {
        "operationId": "createPatientChatInteraction",
        "summary": "Create a patient chat interaction",
        "description": "Validates an active care episode recovery, merges optional client-supplied patient_display_name into interaction context, and creates a chat interaction via service-to-service call. Does not call Chat when no recovery exists.",
        "parameters": [
          {
            "name": "patient_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateChatInteractionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Chat interaction created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatInteractionCreateResponse"
                }
              }
            }
